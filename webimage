<script>
    // Hero Slider Functionality
    let currentSlide = 0;
    const slides = document.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.dot');
    const sliderWrapper = document.getElementById('sliderWrapper');
    let slideInterval;

    function goToSlide(index) {
        slides[currentSlide].classList.remove('active');
        dots[currentSlide].classList.remove('active');
        
        currentSlide = index;
        
        sliderWrapper.style.transform = `translateX(-${currentSlide * 20}%)`;
        
        slides[currentSlide].classList.add('active');
        dots[currentSlide].classList.add('active');
        
        resetInterval();
    }

    function nextSlide() {
        let next = (currentSlide + 1) % slides.length;
        goToSlide(next);
    }

    function resetInterval() {
        clearInterval(slideInterval);
        slideInterval = setInterval(nextSlide, 6000); // 6 seconds per slide
    }

    // Initialize slider
    resetInterval();

    // Mobile Menu Toggle
    const menuToggleBtn = document.getElementById('menuToggleBtn');
    const mainNavbarMenu = document.getElementById('mainNavbarMenu');

    menuToggleBtn.addEventListener('click', () => {
        mainNavbarMenu.classList.toggle('mobile-active');
    });

    // Mobile Dropdown Toggle
    const dropdowns = document.querySelectorAll('.dropdown');
    dropdowns.forEach(dropdown => {
        const link = dropdown.querySelector('a.nav-item-link');
        link.addEventListener('click', (e) => {
            if (window.innerWidth <= 1200) {
                e.preventDefault();
                dropdown.classList.toggle('open-active');
            }
        });
    });
</script>

